{
  "$meta": {
    "name": "ZAZEMLI Design Tokens",
    "version": "1.0.1",
    "status": "draft",
    "source": "brand-v3.html + ZAZEMLI_DESIGN_SYSTEM_v1.0.md (CANDIDATE-2) + ZAZEMLI_DESIGN_SYSTEM_RESEARCH_v1.0.md",
    "date": "2026-05-13",
    "scope": "digital only (web). Print CMYK + mm-эквиваленты frame остаются в PRINT_BRIEF_V4.",
    "changelog": {
      "1.0.1": "Closed null: border.frame3 (journal + leaflet) and border.frame1Ring — values found in brand-v3 lines 4767-4807 + 1598",
      "1.0.0": "Initial draft from brand-v3 §04+§05+§18 + DS v1.0 §2"
    }
  },
  "color": {
    "brand": {
      "bone": "#F6F4F0",
      "charcoal": "#1C1C1C",
      "moss": "#4A7C59",
      "chalk": "#EDEBE6"
    },
    "earth": {
      "graphite": "#2E2E2E",
      "soil": "#6B4D35",
      "ceramsite": "#B08C5A",
      "pumice": "#B5AFA3",
      "sand": "#C8B8A8",
      "gravel": "#D2C9B8"
    },
    "sku": {
      "monstera": "#4A7C59",
      "epipremnum": "#4A7C59",
      "ficus": "#BE3A6B",
      "aglaonema": "#7E6AAF",
      "zamioculcas": "#C47A10",
      "spathiphyllum": "#2878AE",
      "anthurium": "#C03A30"
    },
    "skuByName": {
      "cosmos": "#BE3A6B",
      "iris": "#7E6AAF",
      "buttercup": "#C47A10",
      "sky": "#2878AE",
      "poppy": "#C03A30",
      "moss": "#4A7C59"
    },
    "rule": {
      "ratio": "60/30/10",
      "60": "bone",
      "30": "charcoal",
      "10": "moss",
      "skuPolicy": "only on /collectio/[plant] of matching SKU; never 2+ SKU colors on one page"
    }
  },
  "typography": {
    "family": {
      "system": "Unbounded",
      "narrative": "Spectral",
      "handwritten": "Caveat"
    },
    "weight": {
      "unbounded": [300, 400, 500, 700, 800, 900],
      "spectral": [400, 700],
      "caveat": [400]
    },
    "scale": {
      "xs": 12,
      "sm": 14,
      "base": 16,
      "lg": 20,
      "xl": 24,
      "2xl": 30,
      "3xl": 38,
      "4xl": 48,
      "5xl": 60,
      "6xl": 76
    },
    "scaleRem": {
      "xs": 0.75,
      "sm": 0.875,
      "base": 1.0,
      "lg": 1.25,
      "xl": 1.5,
      "2xl": 1.875,
      "3xl": 2.375,
      "4xl": 3.0,
      "5xl": 3.75,
      "6xl": 4.75
    },
    "fluid": {
      "heroHome": "clamp(2.5rem, 5vw, 4.75rem)",
      "heroInner": "clamp(1.5rem, 3vw, 2.375rem)"
    },
    "lineHeight": {
      "display": 1.0,
      "hero": 1.05,
      "heading": 1.15,
      "body": 1.5,
      "narrative": 1.65,
      "caveat": 1.3
    },
    "letterSpacing": {
      "kicker": "0.18em",
      "captionUppercase": "0.25em",
      "body": "0",
      "headingTight": "-0.025em",
      "displayTight": "-0.05em",
      "displayExtraTight": "-0.075em"
    },
    "rolesUnbounded": {
      "wordmark": { "weight": 500, "size": 16 },
      "display": { "weight": 900, "size": 76 },
      "compressedHero": { "weight": 800, "size": 60 },
      "bodyHero": { "weight": 700, "sizeRange": [38, 48] },
      "h2": { "weight": 500, "size": 24 },
      "body": { "weight": 400, "size": 16 },
      "caption": { "weight": 400, "size": 12 }
    }
  },
  "space": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "6": 24,
    "8": 32,
    "12": 48,
    "16": 64,
    "24": 96,
    "32": 128,
    "semantic": {
      "sectionPaddingYDesktop": 96,
      "sectionPaddingYMobile": 64,
      "sectionGapDesktop": 64,
      "sectionGapMobile": 48,
      "blockGap": 32,
      "itemGap": 16,
      "tightGap": 8
    }
  },
  "opacity": {
    "textDisplay": 0.8,
    "textLatin": 0.75,
    "textNarrative": 0.7,
    "textSecondary": 0.5,
    "textCaption": 0.4,
    "borderDivider": 0.3,
    "caveat": 0.85,
    "dayLabels": 0.55,
    "watermarkMin": 0.06,
    "watermarkMax": 0.2
  },
  "radius": {
    "flat": 0,
    "tight": 2,
    "pill": 999
  },
  "border": {
    "hairline": { "width": 1, "opacity": 0.3 },
    "frame2": {
      "outer": { "width": 1, "opacity": 0.5 },
      "inner": { "width": 0.5, "opacity": 0.3 },
      "gap": 6,
      "color": "charcoal",
      "usage": "default apothecary frame for cards, sections, leaflet back"
    },
    "frame3": {
      "journal": {
        "outer": { "width": 1, "opacity": 0.5 },
        "middle": { "width": 1, "opacity": 0.5 },
        "inner": { "width": 0.5, "opacity": 0.3 },
        "color": "charcoal",
        "source_print_mm": [0.35, 0.35, 0.25],
        "usage": "обложки и задние обложки журнала (digital — для разворотов лендинга на heritage-страницах)"
      },
      "leaflet": {
        "outer": { "width": 1, "opacity": 0.55 },
        "middle": { "width": 1, "opacity": 0.55 },
        "inner": { "width": 1, "opacity": 0.3 },
        "gaps": [12, 8],
        "color": "charcoal",
        "source_print_mm": [0.35, 0.35, 0.30],
        "source_gaps_mm": [3, 2],
        "usage": "печатная листовка front+back. В вебе использовать редко — тонкое декоративное обрамление",
        "_note": "px-значения конвертированы из mm (1mm ≈ 3.78px при 96dpi), округлены до целых px"
      }
    },
    "frame1Ring": {
      "width": 1,
      "color": "moss",
      "opacity": 0.5,
      "fill": "none",
      "radiusPctOfTrim": 0.94,
      "source_print_mm": 0.33,
      "usage": "медальоны ⌀80/100/120, мини ⌀40, favicon, аватар, app-icon. Единственный frame на moss (не charcoal)"
    },
    "input": { "width": 1, "opacity": 0.15, "color": "charcoal" },
    "inputFocus": { "width": 1, "opacity": 1, "color": "moss" }
  },
  "motion": {
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "emphasized": "cubic-bezier(0.2, 0, 0, 1)"
    },
    "duration": {
      "fast": 150,
      "base": 200,
      "medium": 300,
      "slow": 400,
      "page": 600
    },
    "animatable": ["opacity", "transform.translateY", "transform.scale", "border-color", "background-color"],
    "notAnimatable": ["font-size", "color", "display", "margin", "padding", "width", "height"],
    "translateYRange": [5, 10],
    "scaleMax": 1.02
  },
  "shadow": null,
  "fleuron": {
    "glyph": "❦",
    "color": "moss",
    "opacity": 0.8,
    "font": "Spectral"
  },
  "breakpoint": {
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1536
  },
  "a11y": {
    "charcoalOnBone": { "ratio": 15.5, "level": "AAA" },
    "mossOnBone": { "ratio": 5.2, "level": "AA" },
    "skyOnBone": { "ratio": 5.0, "level": "AA" },
    "poppyOnBone": { "ratio": 5.5, "level": "AA" },
    "cosmosOnBone": { "ratio": 3.8, "level": "AA-large-only" },
    "irisOnBone": { "ratio": 3.5, "level": "AA-large-only" },
    "buttercupOnBone": { "ratio": 3.5, "level": "AA-large-only" }
  },
  "$notes": {
    "policyReminders": [
      "shadow: null — явный запрет box-shadow",
      "radius.tight=2 — острые углы, запрет mainstream скруглений 4px+",
      "earth-палитра НЕ применяется как фон секции, только в MaterialDot",
      "frame1Ring — единственный frame на moss; остальные на charcoal",
      "frame3.leaflet px-значения inferred из mm (1mm ≈ 3.78px); journal вариант — прямой mapping в DS v1.0"
    ],
    "printValues": "mm-значения frame для типографии остаются в PRINT_BRIEF_V4. tokens.json — только digital."
  }
}
